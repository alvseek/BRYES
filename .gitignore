# Runtime image artifacts — screenshots & visual proofs (regenerate via phase tests).
# Ignored wholesale so no screenshot slips through prefix-matching. Written via paths.py.
/artifacts/*
!/artifacts/.gitkeep

# Secrets — never commit. Only .env.example (no real values) is tracked.
.env

# Python
__pycache__/
*.pyc
.venv/

# Local dev tools — Android platform-tools (adb) for the PhoneDevice; ~15MB of
# binaries, installed locally, never committed. PhoneDevice references adb by path.
/tools/
